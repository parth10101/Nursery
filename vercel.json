{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/",
      "destination": "frontend/pages/index.html"
    },
    {
      "source": "/admin",
      "destination": "frontend/admin/dashboard.html"
    },
    {
      "source": "/(css|js|images|admin|pages|uploads)/(.*)",
      "destination": "frontend/$1/$2"
    }
  ]
}
