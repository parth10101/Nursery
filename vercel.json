{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin/index"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/admin/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/frontend/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/pages/$1"
    }
  ]
}
