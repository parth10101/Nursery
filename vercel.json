{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/frontend/admin/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/pages/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/pages/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/frontend/pages/images/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/pages/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/pages/$1"
    }
  ]
}
