{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "frontend/admin/$1"
    },
    {
      "source": "/css/(.*)",
      "destination": "frontend/pages/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "frontend/pages/js/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "frontend/pages/images/$1"
    },
    {
      "source": "/",
      "destination": "frontend/pages/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/pages/$1"
    }
  ]
}
